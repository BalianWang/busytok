{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Busytok main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "allow-invoke-busytok",
    "allow-log-frontend-event",
    "allow-flush-frontend-logs",
    "allow-prompt-palette-paste-active-app",
    "allow-prompt-palette-accessibility-status",
    "allow-prompt-palette-open-accessibility-settings",
    "allow-desktop-host-shortcut-diagnostics",
    "allow-desktop-host-retry-shortcut-registration",
    "allow-desktop-host-show-gui",
    "allow-install-version"
  ]
}
