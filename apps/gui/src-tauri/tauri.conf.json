{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Busytok",
  "version": "0.0.15",
  "identifier": "com.busytok.gui",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Busytok",
        "width": 1160,
        "height": 700,
        "minWidth": 700,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/busytok-service",
      "binaries/busytok"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "SimplifiedChinese"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBOUNBRDU0Mzc5MEIyRjUKUldUMXNwQTNWSzJjK2h4aUdsdUdGSGhxbGVQNzdMRUtueWh3b3lIb1FQY21adkhLd2VsY0dzc0EK",
      "endpoints": [
        "https://github.com/BalianWang/busytok/releases/latest/download/latest.json"
      ]
    }
  }
}
